# ============================================================================
# Spira AI relay — 設定ファイル
# ============================================================================
#
# このファイルをコピーして `spira-ai-relay.env` (拡張子から .example を除いた
# 名前) として保存し、自分の環境に合わせて値を編集してください。
#
#   PowerShell:   Copy-Item spira-ai-relay.env.example spira-ai-relay.env
#   コマンド:     copy spira-ai-relay.env.example spira-ai-relay.env
#
# `spira-ai-relay.env` は .gitignore で除外されており、リポジトリには
# コミットされません (秘密情報を安全に入れられます)。
#
# 形式: 1 行 1 設定、KEY=VALUE。コメントは `#` から行末まで。
# クォート (`"..."` / `'...'`) があれば自動で剥がします。
# ============================================================================

# 社内 AI ゲートウェイの URL (パスまで含む完全形)
SPIRA_AI_TARGET=https://gateway.example.com/myapi

# オンプレ プロキシの URL (不要なら空 or 行ごと削除)
SPIRA_AI_PROXY=http://onprem-proxy.example.com:8080

# ローカル listen ポート (Spira 側「ベース URL」と同期させる)
SPIRA_AI_PORT=18080

# 任意: 自己署名証明書を許容 (検証用途のみ、本番禁止)
# 値を `1` にすると有効。
# SPIRA_AI_SKIP_CERT_CHECK=0
